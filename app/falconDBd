#!/bin/bash
#
# falconDBd — Controller script for falconDB
# Usage: falconDBd {start|stop|restart|stat}
#
# Reads app/etc/configure.json and manages the RP and all DN servers
# using 'forever' to keep them alive.
#

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG_FILE="$PROJECT_ROOT/app/etc/configure.json"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# ── Helpers ──────────────────────────────────────────────────────────

log_info()  { echo -e "${GREEN}[INFO]${NC}  $1"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

check_config() {
  if [ ! -f "$CONFIG_FILE" ]; then
    log_error "Configuration file not found: $CONFIG_FILE"
    exit 1
  fi
}

# Check if 'forever' is available
check_forever() {
  if ! command -v forever &> /dev/null; then
    log_warn "'forever' not found globally. Attempting with npx..."
    FOREVER_CMD="npx -y forever"
  else
    FOREVER_CMD="forever"
  fi
}

# Parse JSON config using node (no jq dependency)
parse_config() {
  node -e "
    const cfg = require('$CONFIG_FILE');
    // Output RP
    console.log('RP:' + cfg.rp.id + ':' + cfg.rp.host + ':' + cfg.rp.port);
    // Output all DN servers
    cfg.dn_groups.forEach(g => {
      g.servers.forEach(s => {
        console.log('DN:' + s.id + ':' + s.host + ':' + s.port + ':' + g.id);
      });
    });
  "
}

# ── Commands ─────────────────────────────────────────────────────────

do_start() {
  check_config
  check_forever

  log_info "Starting falconDB..."

  # Parse configuration
  local config_lines
  config_lines=$(parse_config)

  # Start RP first
  while IFS=':' read -r type id host port group_id; do
    if [ "$type" = "RP" ]; then
      log_info "Starting Reverse Proxy ($id) on $host:$port"
      $FOREVER_CMD start \
        --uid "falcondb-$id" \
        --append \
        -o "$PROJECT_ROOT/app/logs/rp/forever.log" \
        -e "$PROJECT_ROOT/app/logs/rp/forever-err.log" \
        "$PROJECT_ROOT/app/src/rp/server.js"
    fi
  done <<< "$config_lines"

  # Small delay to let RP start before DNs try to register
  sleep 1

  # Start all DN servers
  while IFS=':' read -r type id host port group_id; do
    if [ "$type" = "DN" ]; then
      log_info "Starting Data Node ($id) in group $group_id on $host:$port"
      mkdir -p "$PROJECT_ROOT/app/logs/$id"
      $FOREVER_CMD start \
        --uid "falcondb-$id" \
        --append \
        -o "$PROJECT_ROOT/app/logs/$id/forever.log" \
        -e "$PROJECT_ROOT/app/logs/$id/forever-err.log" \
        "$PROJECT_ROOT/app/src/dn/server.js" "$id"
    fi
  done <<< "$config_lines"

  log_info "falconDB started. Use 'falconDBd stat' to check status."
}

do_stop() {
  check_config
  check_forever

  log_info "Stopping falconDB..."

  # Try graceful shutdown via RP /stop first
  local rp_info
  rp_info=$(parse_config | grep "^RP:")
  if [ -n "$rp_info" ]; then
    IFS=':' read -r type id host port <<< "$rp_info"
    log_info "Sending graceful stop to RP at $host:$port"
    curl -s "http://$host:$port/stop" > /dev/null 2>&1 || true
    sleep 2
  fi

  # Force stop all forever processes matching our UIDs
  $FOREVER_CMD stopall 2>/dev/null || true

  log_info "falconDB stopped."
}

do_restart() {
  log_info "Restarting falconDB..."
  do_stop
  sleep 1
  do_start
}

do_stat() {
  check_config

  echo -e "${CYAN}═══════════════════════════════════════════════════════${NC}"
  echo -e "${CYAN}  falconDB System Status${NC}"
  echo -e "${CYAN}═══════════════════════════════════════════════════════${NC}"

  local config_lines
  config_lines=$(parse_config)

  # Query RP
  while IFS=':' read -r type id host port group_id; do
    if [ "$type" = "RP" ]; then
      echo -e "\n${GREEN}[RP] $id ($host:$port)${NC}"
      local resp
      resp=$(curl -s "http://$host:$port/status" 2>/dev/null)
      if [ $? -eq 0 ] && [ -n "$resp" ]; then
        echo "  Status: $(echo "$resp" | node -e "process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);console.log(j.data?.status||'unknown')}catch(e){console.log('parse error')}})" 2>/dev/null)"
      else
        echo -e "  Status: ${RED}UNREACHABLE${NC}"
      fi
    fi
  done <<< "$config_lines"

  # Query all DNs
  while IFS=':' read -r type id host port group_id; do
    if [ "$type" = "DN" ]; then
      echo -e "\n${YELLOW}[DN] $id (group: $group_id, $host:$port)${NC}"
      local resp
      resp=$(curl -s "http://$host:$port/status" 2>/dev/null)
      if [ $? -eq 0 ] && [ -n "$resp" ]; then
        echo "  Status: $(echo "$resp" | node -e "process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);console.log('alive, role=' + (j.data?.role||'?'))}catch(e){console.log('parse error')}})" 2>/dev/null)"
      else
        echo -e "  Status: ${RED}UNREACHABLE${NC}"
      fi
    fi
  done <<< "$config_lines"

  echo -e "\n${CYAN}═══════════════════════════════════════════════════════${NC}"
}

# ── Main ─────────────────────────────────────────────────────────────

case "$1" in
  start)
    do_start
    ;;
  stop)
    do_stop
    ;;
  restart)
    do_restart
    ;;
  stat)
    do_stat
    ;;
  *)
    echo "Usage: falconDBd {start|stop|restart|stat}"
    exit 1
    ;;
esac
